@Article{app12010155,
  AUTHOR = {Oh and Chaeyeon and Ha and Joonseo and Roh and Heejun},
  TITLE = {A Survey on TLS-Encrypted Malware Network Traffic Analysis Applicable to Security Operations Centers},
  JOURNAL = {Applied Sciences},
  VOLUME = {12},
  YEAR = {2022},
  NUMBER = {1},
  ARTICLE-NUMBER = {155},
  URL = {https://www.mdpi.com/2076-3417/12/1/155},
  ISSN = {2076-3417},
  ABSTRACT = {Recently, a majority of security operations centers (SOCs) have been facing a critical issue of increased adoption of transport layer security (TLS) encryption on the Internet, in network traffic analysis (NTA). To this end, in this survey article, we present existing research on NTA and related areas, primarily focusing on TLS-encrypted traffic to detect and classify malicious traffic with deployment scenarios for SOCs. Security experts in SOCs and researchers in academia can obtain useful information from our survey, as the main focus of our survey is NTA methods applicable to malware detection and family classification. Especially, we have discussed pros and cons of three main deployment models for encrypted NTA: TLS interception, inspection using cryptographic functions, and passive inspection without decryption. In addition, we have discussed the state-of-the-art methods in TLS-encrypted NTA for each component of a machine learning pipeline, typically used in the state-of-the-art methods.},
  DOI = {10.3390/app12010155}
}

@article{velan2015survey,
  author = {Velan and Petr and Čermák and Milan and Čeleda and Pavel and Drašar and Martin},
  title = {A survey of methods for encrypted traffic classification and analysis},
  journal = {International Journal of Network Management},
  volume = {25},
  number = {5},
  pages = {355-374},
  keywords = {encrypted traffic, monitoring, network, traffic classification, traffic analysis, machine learning, encryption protocols},
  doi = {https://doi.org/10.1002/nem.1901},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/nem.1901},
  eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/nem.1901},
  abstract = {Summary With the widespread use of encrypted data transport, network traffic encryption is becoming a standard nowadays. This presents a challenge for traffic measurement, especially for analysis and anomaly detection methods, which are dependent on the type of network traffic. In this paper, we survey existing approaches for classification and analysis of encrypted traffic. First, we describe the most widespread encryption protocols used throughout the Internet. We show that the initiation of an encrypted connection and the protocol structure give away much information for encrypted traffic classification and analysis. Then, we survey payload and feature-based classification methods for encrypted traffic and categorize them using an established taxonomy. The advantage of some of described classification methods is the ability to recognize the encrypted application protocol in addition to the encryption protocol. Finally, we make a comprehensive comparison of the surveyed feature-based classification methods and present their weaknesses and strengths. Copyright © 2015 John Wiley \& Sons, Ltd.},
  year = {2015}
}

